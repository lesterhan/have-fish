# No client-side env vars needed — /api/* is proxied by the SvelteKit server.
# Set INTERNAL_API_URL at runtime (e.g. in docker-compose) to point at the backend.
# Defaults to http://localhost:8887 if unset.

INTERNAL_API_URL=http://localhost:8887
# Set by CI/Docker build from git SHA. Use 'dev' locally.
PUBLIC_VERSION=dev
