DATABASE_URL=postgres://havefish:havefish@localhost:5432/havefish
TEST_DATABASE_URL=postgres://havefish:havefish@localhost:5432/havefish_test
PORT=8887

# Better Auth — required
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:8887
FRONTEND_URL=http://localhost:8888
# Extra origins allowed to authenticate (comma-separated). Add the backend URL the
# mobile app points at in prod, e.g. https://<host>.<tailnet>.ts.net
TRUSTED_ORIGINS=

# Seed user (run: bun run src/seed-user.ts)
SEED_EMAIL=you@example.com
SEED_PASSWORD=yourpassword

