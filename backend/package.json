    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "better-auth": "^1.5.4",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.28.0"
  }
}
