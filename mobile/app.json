{
  "expo": {
    "name": "have-fish",
    "slug": "have-fish",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "havefish",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lesterhan.havefish"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
