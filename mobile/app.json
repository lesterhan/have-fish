{
  "expo": {
    "name": "have-fish",
    "slug": "have-fish-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "havefish",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lesterhan.havefish"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "updates": {
      "enabled": false
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "131583bb-53ef-45ca-855e-9511b29efefc"
      }
    },
    "owner": "laserdanger-co"
  }
}
