{
  "expo": {
    "name": "have-fish",
    "slug": "have-fish-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "havefish",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lesterhan.havefish"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "./plugins/withReleaseSigning",
      "./plugins/withDebugAppIdSuffix",
      "./plugins/withTailscaleCleartext",
      "@react-native-community/datetimepicker",
      "expo-status-bar"
    ],
    "updates": {
      "enabled": false
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
